{
  "name": "ia-aggregator-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "codex:bootstrap": "npm run prisma:generate && npm run prisma:push",
    "lint": "npm run lint:next && npm run lint:tokens",
    "lint:next": "eslint src --ext .ts,.tsx --max-warnings=0",
    "lint:tokens": "node scripts/validate-tailwind-arbitrary-values.mjs",
    "type-check": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:quality": "playwright test --config=playwright.quality.config.ts",
    "test:quality:update": "playwright test --config=playwright.quality.config.ts --update-snapshots",
    "perf:budget": "node scripts/check-route-budgets.mjs",
    "quality:ci": "npm run lint && npm run type-check && npm run test -- --runInBand --passWithNoTests && npm run build && npm run perf:budget && npm run test:quality"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^6.16.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.7.0",
    "bullmq": "^5.70.4",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "prisma": "^6.16.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  }
}
